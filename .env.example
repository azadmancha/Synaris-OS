[TEMPLATE]
# ── Application ────────────────────────────────────────
# Copy this template to backend/.env and fill in your keys.

# Environment: development, staging, production
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# ── Database ───────────────────────────────────────────
# Local SQLite (no setup needed):
#   DATABASE_URL=sqlite+aiosqlite:///./synaris_local.db
# PostgreSQL (Docker Compose):
DB_PASSWORD=synaris_dev
DATABASE_URL=postgresql+asyncpg://synaris:synaris_dev@postgres:5432/synaris

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant (legacy — Synaris now uses pgvector) ───────
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── Supabase (required for Google OAuth login) ─────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM Provider API Keys ─────────────────────────────
OPENROUTER_API_KEY=
# Multiple keys: comma-separated for automatic rotation on rate limits
# Example: OPENROUTER_API_KEY=key1,key2
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
# Multiple keys: comma-separated, rotated automatically on 429 errors
# Example: GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
GEMINI_API_KEY=

# ── Search APIs (optional) ────────────────────────────
BRAVE_API_KEY=
TAVILY_API_KEY=

# ════════════════════════════════════════════════════════
# FREE-TIER-OPTIMIZED MODEL CONFIG
# All models below are free to use with the corresponding API key.
# ════════════════════════════════════════════════════════
#
# Format: <provider>/<model_name>
#   Groq:          groq/llama-3.3-70b-versatile, groq/llama-3.1-8b-instant
#   Gemini:        gemini/gemini-2.0-flash (1,500 req/day free)
#   OpenRouter:    openrouter/free (auto-router to best free model)
#
# Provider      Free Tier Limits (per day)
#   Groq:         llama-3.1-8b: 14,400 req  |  llama-3.3-70b: 1,000 req
#   Gemini:       ~1,500 req/day across all models
#   OpenRouter:   ~200 req/day on :free models

# ── LiteLLM Model Per Mode (FREE-TIER OPTIMIZED) ─────
# Groq is primary (fastest). Gemini is fallback for deep/research.
# If Groq hits its 1,000 req/day limit, uncomment the OpenRouter lines to use
# openrouter/free (auto-router to best free model, tested 0.7s response).

LITELLM_FAST_MODEL=groq/llama-3.1-8b-instant
LITELLM_BALANCED_MODEL=groq/llama-3.3-70b-versatile
LITELLM_DEEP_MODEL=gemini/gemini-2.0-flash
LITELLM_CODE_MODEL=groq/llama-3.1-8b-instant
LITELLM_RESEARCH_MODEL=gemini/gemini-2.0-flash
LITELLM_MODEL=groq/llama-3.3-70b-versatile

# ── OpenRouter Free Fallback (uncomment when Groq hits daily quota) ──
# When Groq returns 429 rate-limit errors, switch to OpenRouter's free
# auto-router. It picks the best free model available at request time.
#
# To use: comment out the Groq lines above and uncomment the lines below:
# LITELLM_FAST_MODEL=openrouter/free
# LITELLM_BALANCED_MODEL=openrouter/free
# LITELLM_CODE_MODEL=openrouter/free
# LITELLM_DEEP_MODEL=openrouter/free
# LITELLM_RESEARCH_MODEL=openrouter/free
# LITELLM_MODEL=openrouter/free

# ── Provider-Specific Model Overrides ──────────────────
OPENROUTER_MODEL=openrouter/free
# OPENROUTER_FAST_MODEL=qwen/qwen-2.5-7b-instruct
# OPENROUTER_BALANCED_MODEL=openrouter/free
# OPENROUTER_DEEP_MODEL=openrouter/free
# OPENROUTER_CODE_MODEL=openrouter/free
# OPENROUTER_RESEARCH_MODEL=google/gemini-2.0-flash-001

GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FAST_MODEL=gemini-2.0-flash
# GEMINI_BALANCED_MODEL=gemini-2.0-flash
# GEMINI_DEEP_MODEL=gemini-2.5-flash
# GEMINI_RESEARCH_MODEL=gemini-2.5-pro

GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.3-70b-versatile
# GROQ_BALANCED_MODEL=llama-3.3-70b-versatile
# GROQ_DEEP_MODEL=llama-3.3-70b-versatile
# GROQ_CODE_MODEL=llama-3.3-70b-versatile

# ════════════════════════════════════════════════════════
# RATE LIMITING | LOGGING | SENTRY | CORS
# ════════════════════════════════════════════════════════

# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW=60
# LOG_LEVEL=INFO
# LOG_FORMAT=console
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# CORS_ORIGINS_EXTRA=

# ════════════════════════════════════════════════════════
# FRONTEND (used by the Next.js app)
# ════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
