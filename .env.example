[TEMPLATE]
# ── Application ────────────────────────────────────────
# Copy this template to backend/.env and fill in your keys.

# Environment: development, staging, production
APP_ENV=development
DEBUG=true

# Generate a strong random secret for production.
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── Database ───────────────────────────────────────────
# Local SQLite (no setup needed):
#   DATABASE_URL=sqlite+aiosqlite:///./synaris_local.db
# PostgreSQL (Docker Compose):
# Development-only Docker database password. DO NOT reuse in production.
DB_PASSWORD=synaris_dev
DATABASE_URL=postgresql+asyncpg://synaris:synaris_dev@postgres:5432/synaris

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Supabase (required for Google OAuth login) ─────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ════════════════════════════════════════════════════════
# LLM PROVIDERS
# At least ONE API key is required for AI responses.
# ════════════════════════════════════════════════════════

# ── Supported Providers ────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Optional / Experimental Providers ──────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Multiple keys: comma-separated for automatic rotation on rate limits
# Example: GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3

# ── Search APIs (optional) ────────────────────────────
# BRAVE_API_KEY=
# TAVILY_API_KEY=

# ════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# Free-tier limits vary by provider, model, and account.
# Check each provider's current documentation before deployment.
# Format: <provider>/<model_name>
# ════════════════════════════════════════════════════════

# ── LiteLLM Model Per Mode ────────────────────────────
# Groq is primary (fastest). Gemini is fallback for deep/research.
LITELLM_FAST_MODEL=groq/llama-3.1-8b-instant
LITELLM_BALANCED_MODEL=groq/llama-3.3-70b-versatile
LITELLM_DEEP_MODEL=gemini/gemini-2.0-flash
LITELLM_CODE_MODEL=groq/llama-3.1-8b-instant
LITELLM_RESEARCH_MODEL=gemini/gemini-2.0-flash
LITELLM_MODEL=groq/llama-3.3-70b-versatile

# ── OpenRouter Free Fallback ──────────────────────────
# Uncomment when Groq hits daily quota:
# LITELLM_FAST_MODEL=openrouter/free
# LITELLM_BALANCED_MODEL=openrouter/free
# LITELLM_DEEP_MODEL=openrouter/free
# LITELLM_CODE_MODEL=openrouter/free
# LITELLM_RESEARCH_MODEL=openrouter/free
# LITELLM_MODEL=openrouter/free

# ── Provider-Specific Model Overrides ──────────────────
OPENROUTER_MODEL=openrouter/free
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# ════════════════════════════════════════════════════════
# RATE LIMITING | LOGGING | SENTRY | CORS
# ════════════════════════════════════════════════════════

# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW=60
# LOG_LEVEL=INFO
# LOG_FORMAT=console
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# CORS_ORIGINS_EXTRA=

# ════════════════════════════════════════════════════════
# FRONTEND (used by the Next.js app)
# ════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
