# ─── Backend Production Environment ───────────────────────
#
# These env vars are needed on your backend hosting platform
# (Render, Railway, Fly.io, or your own VPS).
#
# Copy this file or set these as environment variables on your host.
# For local development, these go in backend/.env

# ─── App ──────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# Generate a strong random secret for production.
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ─── Supabase Auth (for JWT verification) ─────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY= (only needed for admin operations)

# ─── CORS — allow frontend domains ───────────────────────
# Comma-separated list of origins that can call the API
# Include your Vercel production + preview domains
CORS_ORIGINS_EXTRA=https://synaris.vercel.app

# ─── Database ────────────────────────────────────────────
# For production, use a managed PostgreSQL instance (e.g. Supabase DB, Neon, Railway)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/synaris

# ─── LLM API Keys ───────────────────────────────────────
# At minimum, set one of these for the AI to work
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
