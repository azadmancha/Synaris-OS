# ═══════════════════════════════════════════════════════════════
# Synaris — Production Environment
# ═══════════════════════════════════════════════════════════════
#
# Copy this to backend/.env.production and fill in your values.
# 
# Quick reference:
#   - Railway dashboard → Variables tab → paste each key-value pair
#   - For Supabase: https://supabase.com/dashboard → project → Settings → API
#   - For Groq:     https://console.groq.com/keys
#   - For Gemini:   https://aistudio.google.com/apikey
#   - For Sentry:   https://sentry.io/settings/ → Client Keys
#
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── Database (PostgreSQL from Railway) ─────────────────────
# Railway's Postgres plugin injects DATABASE_URL automatically,
# but uses the postgres:// scheme (not postgresql+asyncpg://).
# SQLAlchemy's async driver REQUIRES postgresql+asyncpg://.
#
# SOLUTION: Set a custom DATABASE_URL in Railway dashboard:
#   postgresql+asyncpg://<user>:<pass>@<host>:<port>/<db>
#
# Or reference Railway's auto-injected variables:
#   postgresql+asyncpg://${{Postgres.USERNAME}}:${{Postgres.PASSWORD}}@${{Postgres.HOST}}:${{Postgres.PORT}}/${{Postgres.DATABASE}}
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/synaris

# ── Supabase (for Google OAuth) ────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS — At least ONE is required for AI responses
# ═══════════════════════════════════════════════════════════════

# Groq (fastest, free tier: 30 req/min, 14,400 req/day)
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Gemini (deep reasoning, free tier: 60 req/min)
# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# OpenRouter (200+ models, some free)
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ═══════════════════════════════════════════════════════════════
# CORS — allow your Vercel frontend domain
# ═══════════════════════════════════════════════════════════════
#
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically.
# Add your Vercel domain(s) here (comma-separated):
#
#   CORS_ORIGINS_EXTRA=https://synaris.vercel.app,https://synaris.com
#
CORS_ORIGINS_EXTRA=

# ═══════════════════════════════════════════════════════════════
# ERROR MONITORING (optional — leave blank to skip)
# ═══════════════════════════════════════════════════════════════
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FORMAT=json
