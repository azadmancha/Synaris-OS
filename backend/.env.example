# ═══════════════════════════════════════════════════════════════
# Synaris — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# QUICK START: Add ONE API key below and restart the server.
#
#    Recommended (free, fast): GROQ_API_KEY
#      -> https://console.groq.com/keys
#
#    Alternative (free, good): GEMINI_API_KEY
#      -> https://aistudio.google.com/apikey
#
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# Generate a strong random secret for production.
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ── Database ────────────────────────────────────────────────
# SQLite (local dev, no setup required):
# DATABASE_URL=sqlite+aiosqlite:///./synaris_local.db
#
# PostgreSQL (production):
DATABASE_URL=postgresql+asyncpg://synaris:synaris_dev@localhost:5432/synaris

# ── Redis (optional) ───────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Supabase (optional for local dev, needed for Google OAuth) ─
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS - At least ONE is required for AI responses
# ═══════════════════════════════════════════════════════════════
#
#  Provider    | Free? | Sign Up                              | Env Variable
#  ------------+-------+--------------------------------------+----------------
#  Groq        | YES   | https://console.groq.com/keys       | GROQ_API_KEY
#  Gemini      | YES   | https://aistudio.google.com/apikey   | GEMINI_API_KEY
#  OpenRouter  | YES*  | https://openrouter.ai/keys          | OPENROUTER_API_KEY
#  DeepSeek    | YES   | https://platform.deepseek.com/       | DEEPSEEK_API_KEY
#  Anthropic   | No    | https://console.anthropic.com/       | ANTHROPIC_API_KEY
#  OpenAI      | No    | https://platform.openai.com/api-keys | OPENAI_API_KEY

# ── Supported Providers ─────────────────────────────────────
# Groq (fast inference, free tier)
# Free: 30 req/min, 14,400 req/day. Sign up: https://console.groq.com/keys
GROQ_API_KEY=

# Gemini (deep reasoning, free tier)
# Free: 60 req/min. Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (200+ models, free models available)
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Optional / Experimental Providers ───────────────────────
# DeepSeek (math and code, free tier)
# DEEPSEEK_API_KEY=
# Anthropic (Claude - paid)
# ANTHROPIC_API_KEY=
# OpenAI (GPT - paid)
# OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ADVANCED: Fine-tune which model per learning mode
# ═══════════════════════════════════════════════════════════════

# OpenRouter
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_FAST_MODEL=qwen/qwen-2.5-7b-instruct
# OPENROUTER_BALANCED_MODEL=anthropic/claude-3.5-sonnet

# Gemini
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FAST_MODEL=gemini-2.0-flash
# GEMINI_DEEP_MODEL=gemini-2.5-flash

# Groq
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.3-70b-versatile

# LiteLLM (primary - uses format: <provider>/<model>)
# LITELLM_MODEL=groq/llama-3.3-70b-versatile
# LITELLM_MODEL=gemini/gemini-2.0-flash

# ── Search APIs (optional) ─────────────────────────────────
# BRAVE_API_KEY=
# TAVILY_API_KEY=

# ═══════════════════════════════════════════════════════════════
# ERROR MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════

# ── Sentry (error monitoring, optional) ────────────────────
# Get your DSN at https://sentry.io/settings/projects/ → select project → Client Keys
# The app runs fine without Sentry — leave blank to skip.
SENTRY_DSN=
# Sample rate for performance traces (0.0 to 1.0). 1.0 = 100% in dev, 0.1 in prod.
SENTRY_TRACES_SAMPLE_RATE=1.0
# Sample rate for profiling (0.0 to 1.0). Requires Sentry profiling addon.
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ── Logging (structured via structlog) ─────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: 'console' (colored, human-readable) or 'json' (structured, for prod)
LOG_FORMAT=console
