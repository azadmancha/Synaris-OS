# ── Synaris Frontend — Local Development ──
# Copy this to .env.local and fill in your keys.

# Supabase (required for Google OAuth login)
# Get these from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# API backend URL (defaults to http://localhost:8000/v1 if not set)
NEXT_PUBLIC_API_URL=http://localhost:8000/v1

# Site URL for auth redirects (auto-detected in dev, set for production)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
