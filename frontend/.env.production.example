# ═══════════════════════════════════════════════════════════════
# Synaris Frontend — Production Environment
# ═══════════════════════════════════════════════════════════════
#
# Set these in your Vercel project dashboard:
#   Vercel → Project → Settings → Environment Variables
#
# ═══════════════════════════════════════════════════════════════

# ── Supabase (required for Google OAuth) ───────────────────
# From: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API URL ────────────────────────────────────────
# Your Railway backend URL (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
# Format: https://your-backend.railway.app/v1
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/v1

# ── Site URL ───────────────────────────────────────────────
# Vercel sets this automatically. Only set manually if needed.
# NEXT_PUBLIC_SITE_URL=https://synaris.vercel.app
