# ── Synaris Frontend — Production (Vercel) ──
# Set these in your Vercel dashboard: Project → Settings → Environment Variables
# NEXT_PUBLIC_SITE_URL is automatically set by Vercel.

# Supabase (same credentials as development)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# API backend URL — point to your deployed backend
NEXT_PUBLIC_API_URL=https://your-backend-url.com/v1

# Site URL (Vercel sets this automatically, but set manually if needed)
# NEXT_PUBLIC_SITE_URL=https://synaris.vercel.app
